{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TaskBoard",
  "version": "0.1.0",
  "identifier": "com.wen.taskboard",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "任务看板",
        "url": "http://localhost:17420",
        "width": 1100,
        "height": 740,
        "minWidth": 760,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
